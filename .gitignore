# ==========================================
# ☁️ Cloud Resume & Developer Portfolio .gitignore
# ==========================================

# OS Metadata
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# IDEs and Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.project
.classpath
.settings/

# Node.js / Frontend Tools
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.parcel-cache/
.eslintcache
.stylelintcache
dist/
build/
out/
.sass-cache/

# Python (Lambda & Local Scripts)
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.coverage
htmlcov/
pip-log.txt
pip-delete-this-directory.txt

# Infrastructure as Code (Terraform / CloudFormation / SAM)
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
.aws-sam/
samconfig.toml
dist-lambda/

# Local Environment & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.pub
secrets.json
aws-creds.json
